<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp"
    tools:context=".ui.MainActivity"
    android:background="?attr/colorSurface">

    <!-- Bottom panel -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/histogramRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/rerollSelectedBtn"
        style="@style/RerollButtonStyle"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Reroll Selected"
        android:visibility="gone"
        app:cornerRadius="32dp"
        app:backgroundTint="@color/histogram_selected"
        android:layout_marginStart="110dp"
        android:layout_marginEnd="110dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"/>



    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_panel_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="8dp"
        android:clipToOutline="true">

        <!-- ================= TOP ROW ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/minusBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.175"
                android:text="-" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rollCountText"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.30"
                android:gravity="center"
                android:maxLines="1"
                android:textSize="20sp"
                android:includeFontPadding="false"
                android:text="10 D6"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/plusBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.175"
                android:text="+" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/plusFiveBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.175"
                android:text="+5" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/plusTenBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.175"
                android:text="+10" />

        </LinearLayout>


        <!-- ================= BOTTOM ROW ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/undoBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:text="Undo"
                app:cornerRadius="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />



            <com.google.android.material.button.MaterialButton
                android:id="@+id/newRollBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.6"
                android:text="New Roll"
                app:cornerRadius="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
