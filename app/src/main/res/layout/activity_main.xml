    <!-- Bottom panel -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/histogramRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="20dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_panel_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="8dp"
        android:clipToOutline="true">

        <!-- ================= TOP ROW ( - | 5 | + | +5 | +10 ) ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal">

            <!-- ===== 40% ( - i licznik ) ===== -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/minusBtn"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="-"
                    app:cornerRadius="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    />


                <TextView
                    android:id="@+id/rollCountText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="50"
                    android:background="?attr/colorSurface"
                    android:textColor="?attr/colorOnSurface"
                    style="@style/AppLabelLarge" />

            </LinearLayout>

            <!-- ===== 60% ( +, +5, +10 ) ===== -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.6"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/plusBtn"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="+"
                    app:cornerRadius="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/plusFiveBtn"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="+5"
                    app:cornerRadius="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/plusTenBtn"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="+10"
                    app:cornerRadius="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    />

            </LinearLayout>
        </LinearLayout>

        <!-- ================= BOTTOM ROW ( Undo | New Roll ) ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/undoBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:text="Undo"
                app:cornerRadius="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />



            <com.google.android.material.button.MaterialButton
                android:id="@+id/newRollBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.6"
                android:text="New Roll"
                app:cornerRadius="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
