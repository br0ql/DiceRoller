<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.MainActivity"
    android:padding="16dp">

    <!-- STATE / HISTOGRAM -->
    <TextView
        android:id="@+id/stateText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="120dp"
        android:text="No rolls yet"
        android:textSize="16sp"
        android:background="#EEEEEE"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- DICE VALUE INPUT -->
    <TextView
        android:id="@+id/valueLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dice value"
        app:layout_constraintTop_toBottomOf="@id/stateText"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/valueInput"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:text="1"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/stateText"
        app:layout_constraintStart_toEndOf="@id/valueLabel"
        android:layout_marginStart="12dp"/>

    <!-- REROLL BUTTONS -->
    <Button
        android:id="@+id/rerollEqualBtn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Reroll ="
        app:layout_constraintTop_toBottomOf="@id/valueInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/rerollAboveBtn"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/rerollAboveBtn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Reroll >="
        app:layout_constraintTop_toBottomOf="@id/valueInput"
        app:layout_constraintStart_toEndOf="@id/rerollEqualBtn"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- DELETE BUTTONS -->
    <Button
        android:id="@+id/deleteEqualBtn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Delete ="
        app:layout_constraintTop_toBottomOf="@id/rerollEqualBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/deleteAboveBtn"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/deleteAboveBtn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Delete >="
        app:layout_constraintTop_toBottomOf="@id/rerollAboveBtn"
        app:layout_constraintStart_toEndOf="@id/deleteEqualBtn"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- NUMBER OF DICE INPUT -->
    <TextView
        android:id="@+id/countLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Number of dice"
        app:layout_constraintTop_toBottomOf="@id/deleteEqualBtn"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"/>

    <EditText
        android:id="@+id/countInput"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:text="5"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/deleteEqualBtn"
        app:layout_constraintStart_toEndOf="@id/countLabel"
        android:layout_marginStart="12dp"/>

    <!-- BOTTOM ACTIONS -->
    <Button
        android:id="@+id/undoBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Undo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button
        android:id="@+id/newRollBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New roll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>