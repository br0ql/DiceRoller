<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.DiceRoller" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->

        <!-- Main color -->
        <item name="colorPrimary">#8ED8B4</item>

        <!-- Light background -->
        <item name="colorSurface">#DDF3E8</item>

        <!-- Variant of light background -->
        <item name="colorSurfaceVariant">#DDE5E8</item>

        <!-- Text on surface -->
        <item name="colorOnSurface">#71867C</item>

        <!-- Needed for elevate on diceCountText field -->
        <item name="android:windowLightStatusBar">true</item>

        <!-- Style for all material buttons -->
        <item name="materialButtonStyle">@style/AppButtonStyle</item>

    </style>

    <style name="Theme.DiceRoller" parent="Base.Theme.DiceRoller" />

    <!-- Text style -->
    <style name="AppLabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/inter_family</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Style for buttons -->
    <style name="AppButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAppearance">@style/AppLabelLarge</item>
        <item name="android:textColor">@color/button_text_color</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="rippleColor">@color/button_ripple_color</item>
    </style>

    <!-- Reroll floating button style -->
    <style name="RerollButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/AppLabelLarge</item>
        <item name="android:textColor">@color/button_text_color</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:elevation">8dp</item>
    </style>


    <!-- Styles for histogram items -->
    <style name="HistogramValueText">
        <item name="android:textSize">14sp</item>
<!--        <item name="android:textStyle">bold</item>-->
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="HistogramCountText">
        <item name="android:fontFamily">@font/inter_family</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>







</resources>